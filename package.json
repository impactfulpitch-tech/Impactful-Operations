{
  "name": "workflow-hub",
  "version": "1.0.0",
  "description": "Full-stack Workflow Hub application",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "prisma:generate": "npm run prisma:generate -w backend",
    "prisma:migrate": "npm run prisma:migrate -w backend",
    "prisma:push": "npm run prisma:push -w backend",
    "prisma:studio": "npm run prisma:studio -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
